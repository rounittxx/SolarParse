# Streamlit Secrets template.
#
# This file is committed to the repo for documentation only.
# The real secrets.toml lives EITHER:
#   - locally at .streamlit/secrets.toml  (gitignored)
#   - on Streamlit Community Cloud, pasted into the app's
#     Settings -> Secrets panel
#
# When the app starts, st.secrets["GOOGLE_API_KEY"] is read and
# promoted into os.environ so the extractor can use it.

GOOGLE_API_KEY = "your_gemini_key_here"
